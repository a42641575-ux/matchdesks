# Copy this file to .env and adjust as needed.

# Local dev default matches the docker-compose.yml service below, and also
# matches a local Homebrew Postgres role/db named "mapleboard" if you set
# one up manually (see README "Database" section).
DATABASE_URL="postgresql://mapleboard:mapleboard_dev_password@localhost:5432/mapleboard?schema=public"

NEXT_PUBLIC_SITE_URL="https://matchdesks.com"

# Shared secret for the /admin moderation queue login. Set a long random string
# in every environment (do not commit the real value).
ADMIN_SECRET="change-me-to-a-long-random-secret"

# Transactional email via Brevo (optional). If BREVO_API_KEY is unset, admin
# notifications are skipped silently and the app keeps working. To enable:
# create a free Brevo account, verify the sending domain (matchdesks.com) by
# adding Brevo's SPF/DKIM/DMARC records, then paste the API key here.
BREVO_API_KEY=""
# "From" address for app-sent notifications (must be on a Brevo-verified domain).
CONTACT_FROM_EMAIL="hello@matchdesks.com"
# Inbox that receives admin notifications (new pending job, fraud report) — your personal email.
ADMIN_NOTIFY_EMAIL=""
